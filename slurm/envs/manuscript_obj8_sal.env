# manuscript_obj8_sal — full manuscript campaign default.
# Submits the 3-policy ladder (FFMP, FFMP_VR sweep, ANN) at 8 objectives
# with salinity LSTM in-loop. 6 formulations × 10 seeds = 60 jobs.
#
# Use this as the canonical entry point for the production manuscript run:
#   bash slurm/submit_all.sh slurm/envs/manuscript_obj8_sal.env
#
# Temperature LSTM is deferred — see
# local_notes/decisions/2026-04-29_temperature_lstm_deferred.md.

NYCOPT_FORMULATIONS="ffmp,ffmp_6,ffmp_8,ffmp_10,ffmp_12,ann"
NYCOPT_FFMP_VR_N="6,8,10,12"
NYCOPT_SALINITY_ON=1
NYCOPT_TEMPERATURE_ON=0
NYCOPT_SALINITY_ASYNC=0
NYCOPT_OBJECTIVES="nyc_reliability_weekly,nyc_vulnerability,nj_reliability_weekly,montague_reliability_weekly_fixed,trenton_reliability_weekly_fixed,flood_risk_downstream_flow_days,storage_min_combined_pct,salt_front_max_rm_excursion"
NYCOPT_CLUSTER="anvil"
NYCOPT_REEVAL_MODE="mpi"
NYCOPT_REEVAL_N=1
NYCOPT_REEVAL_NODES=4
NYCOPT_REEVAL_RANKS=16
