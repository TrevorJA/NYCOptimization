# ffmp_obj7 — current production baseline (no T/S, 7 objectives).
# Reproduces pre-Phase-0 behavior; outputs land at outputs/{category}/ffmp_obj7/.

NYCOPT_FORMULATIONS="ffmp"
NYCOPT_TS_ON=0
# Leaving NYCOPT_OBJECTIVES unset uses the 7-objective default in config.py.
NYCOPT_CLUSTER="hopper"
NYCOPT_REEVAL_MODE="single"
NYCOPT_REEVAL_N=1
