# manuscript_obj7_sal_sfdv_mult — full manuscript campaign with salinity +
# salt-front multiplier DVs.
#
# Submits the 3-policy ladder (FFMP, FFMP_VR sweep, ANN). FFMP-family
# policies receive the 11 salt-front multiplier DVs via the formulation
# registry; ANN is unaffected (it bypasses FFMP drought levels so the
# salt-front rule never fires for it anyway).
#
# Effective DV counts per architecture:
#   ffmp:        24 + 11 = 35
#   ffmp_8:      26 + 11 = 37
#   ffmp_10:     30 + 11 = 41
#   ffmp_12:     34 + 11 = 45
#   ann:         137         (unchanged)
#
# (ffmp_6 omitted — structurally identical to ffmp.)
#
# Use as the canonical entry point for the production manuscript:
#   bash slurm/submit_all.sh slurm/envs/manuscript_obj7_sal_sfdv_mult.env

NYCOPT_FORMULATIONS="ffmp,ffmp_8,ffmp_10,ffmp_12,ann"
NYCOPT_FFMP_VR_N="8,10,12"
NYCOPT_SALINITY_ON=1
NYCOPT_TEMPERATURE_ON=0
NYCOPT_SALINITY_ASYNC=0
NYCOPT_NYC_NJ_DEMAND_SOURCE="constant_max"
NYCOPT_SALT_FRONT_PARAM_MODE="multipliers"
NYCOPT_OBJECTIVES="nyc_reliability_weekly_decree,nyc_max_deficit_weekly_decree,montague_reliability_weekly_decree,montague_max_deficit_weekly_decree,salt_front_max_rm,flood_days_downstream_action_anygauge,storage_min_combined_pct"
NYCOPT_CLUSTER="anvil"
NYCOPT_REEVAL_MODE="mpi"
NYCOPT_REEVAL_N=1
NYCOPT_REEVAL_NODES=4
NYCOPT_REEVAL_RANKS=16
