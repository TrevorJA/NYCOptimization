# ffmp_obj7_sal_sfdv_mult — FFMP with salinity LSTM + salt-front multiplier DVs.
# 35 DVs total: 24 standard FFMP + 11 free salt-front multiplier cells.
# Slug: ffmp_obj7_sal_sfdv_mult.
#
# Salt-front rule (DRBC §2.5.3) is only active during NYC drought emergency
# (level 5). Outside emergency, the multipliers have no effect — so the
# salt-front DVs only influence rare drought-emergency days. Wider
# benefits show up in long-period sims (78-yr historic) and in stochastic
# drought-of-record ensembles. The 11 multiplier DVs span:
#   Trenton:  decapr (b2,b3), maynov (b0,b2,b3)
#   Montague: decapr (b0,b3), mayaug (b0,b3), sepnov (b0,b3)

NYCOPT_FORMULATIONS="ffmp"
NYCOPT_SALINITY_ON=1
NYCOPT_TEMPERATURE_ON=0
NYCOPT_SALINITY_ASYNC=0
NYCOPT_NYC_NJ_DEMAND_SOURCE="constant_max"
NYCOPT_SALT_FRONT_PARAM_MODE="multipliers"
NYCOPT_OBJECTIVES="nyc_reliability_weekly_decree,nyc_max_deficit_weekly_decree,montague_reliability_weekly_decree,montague_max_deficit_weekly_decree,salt_front_max_rm,flood_days_downstream_action_anygauge,storage_min_combined_pct"
NYCOPT_CLUSTER="anvil"
NYCOPT_REEVAL_MODE="mpi"
NYCOPT_REEVAL_N=1
NYCOPT_REEVAL_NODES=4
NYCOPT_REEVAL_RANKS=16
