# ffmp_obj7_sal — production FFMP baseline reoptimization with salinity LSTM
# in-loop. 7 objectives: mirrored 1954-Decree pairs for NYC and Montague,
# salt-front intrusion, action-stage flood days below NYC reservoirs, and
# storage resilience. Salinity LSTM runs in SYNC mode
# (NYCOPT_SALINITY_ASYNC=0) — required for the LSTM to be responsive to
# NYC operational decisions. Default flow objectives score against the
# static 1954 Decree value, so the LSTM-driven mrf_target rewrite during
# drought emergency does not affect scoring.
# Temperature LSTM is deferred — see decisions/2026-04-29_temperature_lstm_deferred.md.
# Requires drb_ffmp.jar rebuilt for 7 objectives.

NYCOPT_FORMULATIONS="ffmp"
NYCOPT_SALINITY_ON=1
NYCOPT_TEMPERATURE_ON=0
NYCOPT_SALINITY_ASYNC=0
NYCOPT_NYC_NJ_DEMAND_SOURCE="constant_max"
NYCOPT_OBJECTIVES="nyc_reliability_weekly_decree,nyc_max_deficit_weekly_decree,montague_reliability_weekly_decree,montague_max_deficit_weekly_decree,salt_front_max_rm,flood_days_downstream_action_anygauge,storage_min_combined_pct"
NYCOPT_CLUSTER="anvil"
NYCOPT_REEVAL_MODE="mpi"
NYCOPT_REEVAL_N=1
NYCOPT_REEVAL_NODES=4
NYCOPT_REEVAL_RANKS=16
