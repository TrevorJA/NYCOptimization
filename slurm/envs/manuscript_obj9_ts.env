# manuscript_obj9_ts — full manuscript campaign default.
# Submits the 3-policy ladder (FFMP, FFMP_VR sweep, ANN) at 9 objectives
# with T/S in-loop. 6 formulations × 10 seeds = 60 jobs via submit_all.sh.
#
# Use this as the canonical entry point for the production manuscript run:
#   bash slurm/submit_all.sh slurm/envs/manuscript_obj9_ts.env

NYCOPT_FORMULATIONS="ffmp,ffmp_6,ffmp_8,ffmp_10,ffmp_12,ann"
NYCOPT_FFMP_VR_N="6,8,10,12"
NYCOPT_TS_ON=1
NYCOPT_SALINITY_ASYNC=1
NYCOPT_OBJECTIVES="nyc_reliability_weekly,nyc_vulnerability,nj_reliability_weekly,montague_reliability_weekly_fixed,trenton_reliability_weekly_fixed,flood_risk_downstream_flow_days,storage_min_combined_pct,lordville_thermal_exceedance_days,salt_front_max_rm_excursion"
NYCOPT_CLUSTER="anvil"
NYCOPT_REEVAL_MODE="mpi"
NYCOPT_REEVAL_N=1
NYCOPT_REEVAL_NODES=4
NYCOPT_REEVAL_RANKS=16
