# manuscript_obj7_sal — full manuscript campaign default.
# Submits the 3-policy ladder (FFMP, FFMP_VR sweep, ANN) at 7 objectives
# with salinity LSTM in-loop. 5 formulations × 10 seeds = 50 jobs.
#
# Use this as the canonical entry point for the production manuscript run:
#   bash slurm/submit_all.sh slurm/envs/manuscript_obj7_sal.env
#
# Temperature LSTM is deferred — see
# local_notes/decisions/2026-04-29_temperature_lstm_deferred.md.
# ffmp_6 is omitted from the sweep because it is structurally identical to
# ffmp (see config.py:FFMP_VR_N_SWEEP).

NYCOPT_FORMULATIONS="ffmp,ffmp_8,ffmp_10,ffmp_12,ann"
NYCOPT_FFMP_VR_N="8,10,12"
NYCOPT_SALINITY_ON=1
NYCOPT_TEMPERATURE_ON=0
NYCOPT_SALINITY_ASYNC=0
NYCOPT_NYC_NJ_DEMAND_SOURCE="constant_max"
NYCOPT_OBJECTIVES="nyc_reliability_weekly_decree,nyc_max_deficit_weekly_decree,montague_reliability_weekly_decree,montague_max_deficit_weekly_decree,salt_front_max_rm,flood_days_downstream_action_anygauge,storage_min_combined_pct"
NYCOPT_CLUSTER="anvil"
NYCOPT_REEVAL_MODE="mpi"
NYCOPT_REEVAL_N=1
NYCOPT_REEVAL_NODES=4
NYCOPT_REEVAL_RANKS=16
