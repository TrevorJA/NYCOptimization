# ffmp_obj8_sal_sfdv_full — FFMP with salinity LSTM + full salt-front DV table.
# 39 DVs total: 24 standard FFMP + 11 multipliers + 1 activation gate +
# 3 RM-band thresholds.
#
# Use this mode when you want maximum operational flexibility around the
# salt-front feedback rule, including the option to fire the rule earlier
# in the FFMP staircase (L3 / L4 instead of only L5) and to relocate the
# RM-band boundaries from their DRBC §2.5.3 default values.

NYCOPT_FORMULATIONS="ffmp"
NYCOPT_SALINITY_ON=1
NYCOPT_TEMPERATURE_ON=0
NYCOPT_SALINITY_ASYNC=0
NYCOPT_SALT_FRONT_PARAM_MODE="full"
NYCOPT_OBJECTIVES="nyc_reliability_weekly,nyc_vulnerability,nj_reliability_weekly,montague_reliability_weekly_fixed,trenton_reliability_weekly_fixed,flood_risk_downstream_flow_days,storage_min_combined_pct,salt_front_max_rm_excursion"
NYCOPT_CLUSTER="anvil"
NYCOPT_REEVAL_MODE="mpi"
NYCOPT_REEVAL_N=1
NYCOPT_REEVAL_NODES=4
NYCOPT_REEVAL_RANKS=16
