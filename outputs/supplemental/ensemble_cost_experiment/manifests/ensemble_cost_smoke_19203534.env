# ensemble_cost — the t_eval(N, L, model) cost-surface benchmark
# (workflow/supplemental/ensemble_cost_stage_submit.sh -> ensemble_cost_sweep.sh).
#
# Identity matches the campaign's evaluation path (7-objective FFMP, no LSTM) on
# a stationary Kirsch-Nowak stand-in ensemble. Per-eval cost is set by ensemble
# SHAPE (N realizations x L years) and model variant, not by scenario content,
# so the stand-in is interchangeable with any campaign design's ensemble of the
# same shape.
#
# The swept knobs are deliberately NOT set here — the sweep script exports them
# per cell, and a value here would pin every cell to one shape/variant:
#   NYCOPT_SCALING_KN_REALS   N realizations
#   NYCOPT_SCALING_KN_YEARS   L years
#   NYCOPT_USE_TRIMMED_MODEL  1 = trimmed (search path), 0 = full (re-eval path)
#
# PREREQUISITE: every (N, L) cell must be staged first — workflow steps 02
# (generate kn_{Y}yr_n{N}) -> 04 (prep pywrdrb inputs), each with
# NYCOPT_SCENARIO_DESIGN=scaling_stationary (step 03 applies only to the
# hazard-filling designs). ensemble_cost_stage_submit.sh submits both for every
# unstaged cell; the sweep script's pre-flight fails fast otherwise.
#
# Do NOT add PYWRDRB_SIM_* or DEBUG_SIM here: the ensemble window self-derives
# from the realization length (src/simulation.py::_ensemble_window) and a date
# override would shift it off the staged HDF5 date axis.

NYCOPT_SCENARIO_DESIGN="scaling_stationary"
NYCOPT_MOEA_CONFIG="pilot"

NYCOPT_FORMULATIONS="ffmp"
NYCOPT_SALINITY_ON=0
NYCOPT_TEMPERATURE_ON=0
NYCOPT_NYC_NJ_DEMAND_SOURCE="constant_max"
NYCOPT_OBJECTIVES="nyc_delivery_reliability_weekly,nyc_delivery_deficit_cvar90_pct,montague_flow_reliability_weekly,montague_flow_deficit_cvar90_pct,trenton_flow_reliability_weekly,downstream_flood_days_minor,nyc_storage_p5_pct"
NYCOPT_CLUSTER="anvil"
