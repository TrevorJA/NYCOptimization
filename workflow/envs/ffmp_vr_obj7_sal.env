# ffmp_vr_obj7_sal — variable-resolution FFMP sweep N∈{8,10,12} with salinity
# LSTM in-loop. Submit one independent job per N value:
#   sbatch --export=ALL,NYCOPT_ENV_FILE=workflow/envs/ffmp_vr_obj7_sal.env,FORMULATION=ffmp_8 \
#          --array=1-10 workflow/06_run_mmborg.sh     # then ffmp_10, ffmp_12
# Each N produces a slug like ffmp_8_obj7_sal, ffmp_10_obj7_sal, ...
# (N=6 is omitted because it is structurally identical to baseline ffmp.)

# Run axes (scenario design + MOEA config). Outputs land under
# outputs/{scenario}/{moea_slug}/. See src/scenario_designs.py + src/moea_config.py.
NYCOPT_SCENARIO_DESIGN="historic"
# mm_full = fully-specified production config (see src/moea_config.py).
# The schema-only "production" config has all-None numbers and cannot launch.
NYCOPT_MOEA_CONFIG="mm_full"

NYCOPT_FORMULATIONS="ffmp_8,ffmp_10,ffmp_12"
NYCOPT_FFMP_VR_N="8,10,12"
NYCOPT_SALINITY_ON=1
NYCOPT_TEMPERATURE_ON=0
NYCOPT_SALINITY_ASYNC=0
NYCOPT_NYC_NJ_DEMAND_SOURCE="constant_max"
NYCOPT_OBJECTIVES="nyc_delivery_reliability_weekly,nyc_delivery_deficit_cvar90_pct,montague_flow_reliability_weekly,montague_flow_deficit_cvar90_pct,salt_front_intrusion_max_rm,downstream_flood_days_minor,nyc_storage_p5_pct"
NYCOPT_CLUSTER="anvil"
NYCOPT_REEVAL_MODE="mpi"
NYCOPT_REEVAL_N=1
NYCOPT_REEVAL_NODES=4
NYCOPT_REEVAL_RANKS=16
