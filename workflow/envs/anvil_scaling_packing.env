# anvil_scaling_packing — Stage A (node-packing sweep) of the Anvil scaling
# experiment (workflow/supplemental/anvil_scaling_packing.sh). Identity matches
# the scenario-design campaign's evaluation path (7-objective FFMP, no LSTM,
# trimmed-model ensemble evaluation) on a stationary Kirsch-Nowak stand-in
# ensemble: the hazard-filling search ensemble is not yet generatable (scengen
# master generation unimplemented), and per-eval cost is set by ensemble SHAPE
# (N realizations x L years), not scenario content. Default 20 x 20yr via the
# scaling_stationary design (NYCOPT_SCALING_KN_YEARS/_REALS to resize).
#
# PREREQUISITE: the stand-in ensemble must be staged first — workflow steps
# 02 (generate kn_{Y}yr_n{N}) -> 04 (prep pywrdrb inputs), each with
# NYCOPT_SCENARIO_DESIGN=scaling_stationary (step 03 does not apply to
# stationary designs). The packing script's pre-flight fails fast otherwise.
#
# Do NOT add PYWRDRB_SIM_* or DEBUG_SIM here: the ensemble window self-derives
# from the realization length (src/simulation.py::_ensemble_window) and a date
# override would shift it off the staged HDF5 date axis.

NYCOPT_SCENARIO_DESIGN="scaling_stationary"
NYCOPT_MOEA_CONFIG="pilot"

NYCOPT_FORMULATIONS="ffmp"
NYCOPT_SALINITY_ON=0
NYCOPT_TEMPERATURE_ON=0
NYCOPT_NYC_NJ_DEMAND_SOURCE="constant_max"
NYCOPT_OBJECTIVES="nyc_delivery_reliability_weekly,nyc_delivery_deficit_cvar90_pct,montague_flow_reliability_weekly,montague_flow_deficit_cvar90_pct,trenton_flow_reliability_weekly,downstream_flood_days_minor,nyc_storage_p5_pct"
NYCOPT_CLUSTER="anvil"
