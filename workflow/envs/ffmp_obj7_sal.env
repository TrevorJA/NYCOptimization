# ffmp_obj7_sal — FFMP baseline reoptimization with salinity LSTM in-loop.
# Salinity-variant 7-objective set: NYC delivery reliability + CVaR90 deficit,
# Montague flow reliability + CVaR90 deficit, salt-front intrusion (diagnostic
# metric used here as the salinity objective in place of Trenton flow), minor-
# stage downstream flood days, and storage p5 resilience. Salinity LSTM runs in
# SYNC mode
# (NYCOPT_SALINITY_ASYNC=0) — required for the LSTM to be responsive to
# NYC operational decisions. Default flow objectives score against the
# static 1954 Decree value, so the LSTM-driven mrf_target rewrite during
# drought emergency does not affect scoring.
# Temperature LSTM is deferred — see decisions/2026-04-29_temperature_lstm_deferred.md.
# Requires drb_ffmp.jar rebuilt for 7 objectives.

# Run axes (the two named identifiers that, with the formulation + objectives
# + physics below, fully specify a run). Scenario design = the search ensemble
# (src/scenario_designs.py); MOEA config = Borg algorithm settings
# (src/moea_config.py). Outputs land under outputs/{scenario}/{moea_slug}/.
NYCOPT_SCENARIO_DESIGN="historic"
# mm_full = fully-specified production config (4 islands x 40 workers,
# 50k NFE, historic single-trace baseline). The schema-only "production" config
# has all-None numbers and cannot launch (mmborg fails fast) — see
# src/moea_config.py.
NYCOPT_MOEA_CONFIG="mm_full"

NYCOPT_FORMULATIONS="ffmp"
NYCOPT_SALINITY_ON=1
NYCOPT_TEMPERATURE_ON=0
NYCOPT_SALINITY_ASYNC=0
NYCOPT_NYC_NJ_DEMAND_SOURCE="constant_max"
NYCOPT_OBJECTIVES="nyc_delivery_reliability_weekly,nyc_delivery_deficit_cvar90_pct,montague_flow_reliability_weekly,montague_flow_deficit_cvar90_pct,salt_front_intrusion_max_rm,downstream_flood_days_minor,nyc_storage_p5_pct"
NYCOPT_CLUSTER="anvil"
NYCOPT_REEVAL_MODE="mpi"
NYCOPT_REEVAL_N=1
NYCOPT_REEVAL_NODES=4
NYCOPT_REEVAL_RANKS=16
