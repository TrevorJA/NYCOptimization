# ffmp_obj7_historic — FFMP historic single-trace 7-objective baseline (no LSTM).
#
# This is the env the canonical launcher slurm/main/mmborg_ffmp.sh defaults to,
# and it satisfies that template's pre-flight: salinity/temperature LSTM OFF, a
# non-ensemble (historic single-trace) search spec, and exactly the default 7
# objectives. Trenton flow reliability is the seventh objective here (the *_sal
# variant swaps it for the salt-front intrusion objective and enables salinity).

# Run axes (scenario design + MOEA config). Outputs -> outputs/{scenario}/{slug}/.
# See src/scenario_designs.py + src/moea_config.py.
NYCOPT_SCENARIO_DESIGN="historic"
# mm_full = fully-specified Hopper production config (4 islands x 40 workers,
# 50k NFE). Use mm_pilot/pilot for the launch-verification run.
NYCOPT_MOEA_CONFIG="mm_full"

NYCOPT_FORMULATIONS="ffmp"
NYCOPT_SALINITY_ON=0
NYCOPT_TEMPERATURE_ON=0
NYCOPT_NYC_NJ_DEMAND_SOURCE="constant_max"
NYCOPT_OBJECTIVES="nyc_delivery_reliability_weekly,nyc_delivery_deficit_cvar90_pct,montague_flow_reliability_weekly,montague_flow_deficit_cvar90_pct,trenton_flow_reliability_weekly,downstream_flood_days_minor,nyc_storage_p5_pct"
NYCOPT_CLUSTER="anvil"
NYCOPT_REEVAL_MODE="mpi"
NYCOPT_REEVAL_N=1
NYCOPT_REEVAL_NODES=4
NYCOPT_REEVAL_RANKS=16
