# ffmp_obj7_hazfill_pilot — launch-verification pilot for the DU-forced
# hazard-filling scenario design (7-objective FFMP, no LSTM, 5k-NFE pilot MOEA
# config).
#
# hazard_filling_du is the central novelty arm: it generates its OWN DU-forced
# candidate pool (i.i.d. theta, one realization per theta), then selects N members
# by LHS anchors + nearest-neighbor snap in hazard space. Its exact control is
# input_stratified (same forcing space, same N, same L; only the selection SPACE
# differs).
#
# PREREQUISITE: the search ensemble must be staged first — workflow steps
# 02 (generate this design's own candidate pool + hazard image) -> 03
# (hazard-filling selection; all K draws in one job) -> 04 (prep pywrdrb inputs;
# once per draw), each with NYCOPT_SCENARIO_DESIGN=hazard_filling_du. Until then
# the MM-Borg pre-flight fails fast with a staging message.

NYCOPT_SCENARIO_DESIGN="hazard_filling_du"
NYCOPT_MOEA_CONFIG="pilot"

NYCOPT_FORMULATIONS="ffmp"
NYCOPT_SALINITY_ON=0
NYCOPT_TEMPERATURE_ON=0
NYCOPT_NYC_NJ_DEMAND_SOURCE="constant_max"
NYCOPT_OBJECTIVES="nyc_delivery_reliability_weekly,nyc_delivery_deficit_cvar90_pct,montague_flow_reliability_weekly,montague_flow_deficit_cvar90_pct,trenton_flow_reliability_weekly,downstream_flood_days_minor,nyc_storage_p5_pct"
NYCOPT_CLUSTER="anvil"
NYCOPT_REEVAL_MODE="mpi"
