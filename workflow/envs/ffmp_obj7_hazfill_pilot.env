# ffmp_obj7_hazfill_pilot — launch-verification pilot for the hazard-filling
# scenario design (7-objective FFMP, no LSTM, 5k-NFE pilot MOEA config).
#
# PREREQUISITE: the hazard-filling search ensemble must be staged first —
# workflow steps 02 (generate master pool) -> 03 (hazard-filling subsample)
# -> 04 (prep pywrdrb inputs), each with NYCOPT_SCENARIO_DESIGN=hazard_filling.
# Until then the MM-Borg pre-flight fails fast with a staging message.

NYCOPT_SCENARIO_DESIGN="hazard_filling"
NYCOPT_MOEA_CONFIG="pilot"

NYCOPT_FORMULATIONS="ffmp"
NYCOPT_SALINITY_ON=0
NYCOPT_TEMPERATURE_ON=0
NYCOPT_NYC_NJ_DEMAND_SOURCE="constant_max"
NYCOPT_OBJECTIVES="nyc_delivery_reliability_weekly,nyc_delivery_deficit_cvar90_pct,montague_flow_reliability_weekly,montague_flow_deficit_cvar90_pct,trenton_flow_reliability_weekly,downstream_flood_days_minor,nyc_storage_p5_pct"
NYCOPT_CLUSTER="anvil"
NYCOPT_REEVAL_MODE="mpi"
NYCOPT_REEVAL_N=1
NYCOPT_REEVAL_NODES=4
NYCOPT_REEVAL_RANKS=16
