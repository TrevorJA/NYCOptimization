# smoke — dev-only end-to-end pipeline check. Tiny NFE (MOEA config "smoke"),
# historic single-trace design, default 7 objectives, no LSTMs. Submitted via
# workflow/submit_smoke.sh, which also applies the short debug simulation
# window and smoke-sized allocation overrides.

NYCOPT_SCENARIO_DESIGN="historic"
NYCOPT_MOEA_CONFIG="smoke"

NYCOPT_SALINITY_ON=0
NYCOPT_TEMPERATURE_ON=0
NYCOPT_CLUSTER="anvil"
