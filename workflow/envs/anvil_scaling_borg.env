# anvil_scaling_borg — Stage B (MM Borg strong scaling) of the Anvil scaling
# experiment (workflow/supplemental/anvil_scaling_borg.sh). Historic
# single-trace design; the SLURM script exports DEBUG_SIM=true so evals run
# the short 2018-2022 window (~13 s/eval) — this stage measures Borg
# coordination overhead, not search quality.
#
# DELIBERATELY NO NYCOPT_MOEA_CONFIG LINE. The geometry is selected per job by
# the submit helper (workflow/supplemental/anvil_scaling_borg_submit.sh) via
#   sbatch --export=ALL,...,NYCOPT_MOEA_CONFIG=scale_1x32 ...
# and `nycopt_source_env_file` (set -a) leaves that submit-time export intact
# because this file never assigns the variable. Valid values are the scale_*
# entries in src/moea_config.py.

NYCOPT_SCENARIO_DESIGN="historic"

NYCOPT_FORMULATIONS="ffmp"
NYCOPT_SALINITY_ON=0
NYCOPT_TEMPERATURE_ON=0
NYCOPT_NYC_NJ_DEMAND_SOURCE="constant_max"
NYCOPT_OBJECTIVES="nyc_delivery_reliability_weekly,nyc_delivery_deficit_cvar90_pct,montague_flow_reliability_weekly,montague_flow_deficit_cvar90_pct,trenton_flow_reliability_weekly,downstream_flood_days_minor,nyc_storage_p5_pct"
NYCOPT_CLUSTER="anvil"
